{
  "name": "aura-ecosystem",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "**/*.{ts,tsx,json,md,css}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "react-hook-form": "7.76.0"
  }
}
