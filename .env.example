# Supabase — mismo proyecto para las 3 apps
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Drizzle — Supabase Postgres connection string (Transaction mode, puerto 6543)
# Lo encontrás en: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgmode=transaction
